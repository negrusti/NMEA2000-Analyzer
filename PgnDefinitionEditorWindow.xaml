<Window x:Class="NMEA2000Analyzer.PgnDefinitionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PGN Definition"
        Height="700"
        Width="900"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,8">
            <DockPanel Margin="0,0,0,8">
                <Button x:Name="AddManufacturerMatchButton"
                        DockPanel.Dock="Left"
                        Content="Add Mfg Match"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Click="AddManufacturerMatchButton_Click" />
                <Button x:Name="SetFastPacketButton"
                        DockPanel.Dock="Left"
                        Content="Set Fast Packet"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Click="SetFastPacketButton_Click" />
                <TextBlock x:Name="MatchHintTextBlock"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
            <TextBlock x:Name="DefinitionSourceTextBlock"
                       TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="ClearDefinitionButton"
                    Content="Clear definition"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="ClearDefinitionButton_Click" />
            <Button Content="Save"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True" />
        </StackPanel>
        <TextBox x:Name="DefinitionTextBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12" />
    </DockPanel>
</Window>
