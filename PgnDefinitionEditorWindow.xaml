<Window x:Class="NMEA2000Analyzer.PgnDefinitionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PGN Definition"
        Height="700"
        Width="900"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <TextBlock x:Name="DefinitionSourceTextBlock"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap" />
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Save"
                    Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True" />
        </StackPanel>
        <TextBox x:Name="DefinitionTextBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12" />
    </DockPanel>
</Window>
