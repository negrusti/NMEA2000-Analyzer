<Window x:Class="NMEA2000Analyzer.CaptureProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCAN Capture"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="15">
            <Run Text="Packets captured: " />
            <Run x:Name="PacketCountRun"
                 Text="0" />
        </TextBlock>

        <Button Grid.Row="1"
                Width="90"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                IsDefault="True"
                Content="Stop"
                Click="StopButton_Click" />
    </Grid>
</Window>
