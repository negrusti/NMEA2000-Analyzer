<Window x:Class="NMEA2000Analyzer.PgnStatistics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PGN Statistics" Height="400" Width="600">
    <Grid>
        <DataGrid x:Name="PgnStatisticsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
          SelectionMode="Extended"
          SelectionUnit="FullRow"
          HorizontalGridLinesBrush="#F0F0F0"
          VerticalGridLinesBrush="#F0F0F0">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="MouseDoubleClick"
                                 Handler="PgnRow_MouseDoubleClick" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Include" Click="IncludeMenuItem_Click" />
                    <MenuItem Header="Exclude" Click="ExcludeMenuItem_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="PGN" Binding="{Binding PGN}" Width="*" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                <DataGridTextColumn Header="Addresses" Binding="{Binding SourceAddresses}" Width="2*" />
                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
