<Window x:Class="NMEA2000Analyzer.AnomaliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anomalies"
        Width="1200"
        Height="620"
        MinWidth="820"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="AnomaliesDataGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HorizontalGridLinesBrush="#F0F0F0"
                  VerticalGridLinesBrush="#F0F0F0"
                  ItemsSource="{Binding}"
                  MouseDoubleClick="AnomaliesDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="180" />
                <DataGridTextColumn Header="Src" Binding="{Binding Source}" Width="Auto" />
                <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="2*" />
                <DataGridTextColumn Header="PGN" Binding="{Binding Pgn}" Width="Auto" />
                <DataGridTextColumn Header="Anomaly" Binding="{Binding Anomaly}" Width="2*" />
                <DataGridTextColumn Header="Previous" Binding="{Binding PreviousValue}" Width="Auto" />
                <DataGridTextColumn Header="Current" Binding="{Binding CurrentValue}" Width="Auto" />
                <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="Auto" />
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="3*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1"
                BorderBrush="#E3E3E3"
                BorderThickness="0,1,0,0"
                Background="#FCFCFC"
                Padding="8,6">
            <TextBlock Foreground="#666666"
                       Text="Double-click a row to go to the corresponding packet in the main view."
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
