<Window x:Class="NMEA2000Analyzer.Devices"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NMEA2000Analyzer"
        mc:Ignorable="d"
        Title="Devices"
        MaxWidth="1000" MaxHeight="800"
        SizeToContent="WidthAndHeight">
    <Grid>
        <DataGrid x:Name="DevicesDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  HorizontalGridLinesBrush="#F0F0F0"
                  VerticalGridLinesBrush="#F0F0F0"
                  ItemsSource="{Binding BindableDevices}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Addr" Binding="{Binding Address}" Width="Auto" />
                <DataGridTextColumn Header="Manufacturer" Binding="{Binding MfgCode}" Width="Auto" />
                <DataGridTextColumn Header="Model ID" Binding="{Binding ModelID}" Width="Auto" />
                <DataGridTextColumn Header="Model Version" Binding="{Binding ModelVersion}" Width="Auto" />
                <DataGridTextColumn Header="Device Function" Binding="{Binding DeviceFunction}" Width="Auto" />
                <DataGridTextColumn Header="Unassembled" Binding="{Binding UnassembledCount}" Width="Auto" />
                <DataGridTextColumn Header="Assembled" Binding="{Binding AssembledCount}" Width="Auto" />
                <DataGridTextColumn Header="Software Version" Binding="{Binding SoftwareVersionCode}" Width="Auto" />
                <DataGridTextColumn Header="Model Serial" Binding="{Binding ModelSerialCode}" Width="Auto" />
                <DataGridTextColumn Header="Prod Code" Binding="{Binding ProductCode}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
